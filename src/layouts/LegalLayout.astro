---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  pageTitle: string;
  pageSubtitle: string;
  breadcrumb: string;
}
const { title, description, pageTitle, pageSubtitle, breadcrumb } = Astro.props;
---

<Layout title={title} description={description}>
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/">Inicio</a> &nbsp;›&nbsp; {breadcrumb}</div>
      <h1>{pageTitle}</h1>
      <p>{pageSubtitle}</p>
    </div>
  </section>
  <div class="legal-wrap">
    <slot />
  </div>
</Layout>

<style>
  .page-hero { padding: var(--space-12) 0; background: linear-gradient(180deg, var(--c-bg) 0%, rgba(170, 191, 173, 0.12) 100%); text-align: center; }
  .page-hero h1 { font-size: var(--fs-h1); margin-bottom: var(--space-4); max-width: 760px; margin-left: auto; margin-right: auto; }
  .page-hero p { font-size: 1.1rem; color: var(--c-text-muted); max-width: 640px; margin: 0 auto; }
  .breadcrumb { font-size: 0.85rem; color: var(--c-text-muted); margin-bottom: var(--space-4); }
  .breadcrumb a { color: var(--c-verde-texto); text-decoration: none; }
  .legal-wrap { max-width: 760px; margin: 0 auto; padding: var(--space-12) var(--space-6); }
  .legal-wrap :global(h2) { font-size: 1.5rem; margin-top: var(--space-12); margin-bottom: var(--space-4); padding-top: var(--space-6); border-top: 1px solid var(--c-border); }
  .legal-wrap :global(h2:first-of-type) { border-top: none; padding-top: 0; margin-top: 0; }
  .legal-wrap :global(h3) { font-size: 1.15rem; margin-top: var(--space-6); margin-bottom: var(--space-3); }
  .legal-wrap :global(p) { margin-bottom: var(--space-4); }
  .legal-wrap :global(ul), .legal-wrap :global(ol) { padding-left: var(--space-6); margin-bottom: var(--space-4); }
  .legal-wrap :global(li) { margin-bottom: var(--space-2); }
  .legal-wrap :global(a) { color: var(--c-verde-texto); }
  .legal-wrap :global(.legal-meta) { background: rgba(170, 191, 173, 0.12); padding: var(--space-6); border-radius: var(--radius-md); margin-bottom: var(--space-8); font-size: 0.92rem; }
  .legal-wrap :global(.toc) { background: var(--c-bg-elev); border: 1px solid var(--c-border); border-radius: var(--radius-md); padding: var(--space-6); margin-bottom: var(--space-8); }
  .legal-wrap :global(.toc h4) { font-family: 'Inter', sans-serif; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.08em; margin-bottom: var(--space-3); color: var(--c-text-muted); font-weight: 600; }
  .legal-wrap :global(.toc ol) { padding-left: var(--space-6); }
  .legal-wrap :global(.toc li) { margin-bottom: var(--space-1); font-size: 0.92rem; }
  .legal-wrap :global(.toc a) { color: var(--c-text-body); text-decoration: none; }
  .legal-wrap :global(.toc a:hover) { color: var(--c-verde-texto); text-decoration: underline; }
</style>
