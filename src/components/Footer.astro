<style>
  footer {
    background: #0d2429; color: rgba(255,255,255,0.7);
    padding: var(--space-16) 0 var(--space-8);
    margin-top: var(--space-16);
  }
  .footer-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-8); }
  @media (min-width: 700px) { .footer-grid { grid-template-columns: 1.5fr 1fr 1fr 1.3fr; } }
  footer h4 {
    color: #fff; font-family: 'Inter', sans-serif; font-weight: 600;
    font-size: 0.95rem; margin-bottom: var(--space-4);
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  footer ul { list-style: none; padding: 0; }
  footer li { margin-bottom: var(--space-2); }
  footer a {
    color: rgba(255,255,255,0.7); text-decoration: none;
    font-size: 0.9rem; transition: color var(--t-fast);
  }
  footer a:hover { color: var(--c-verde-claro); }
  .footer-logo-placeholder {
