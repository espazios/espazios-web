---
import Logo from './Logo.astro';
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Espazios — Inicio">
          <Logo variant="white" />
        </a>
        <p class="footer-tagline">Especialistas en acabados de apartamentos en obra gris.</p>
      </div>
      <div>
        <h4>Modalidades</h4>
        <ul>
          <li><a href="/#productos">Full Acabados</a></li>
          <li><a href="/#productos">Solo Carpintería</a></li>
          <li><a href="/#productos">Solo Obra Blanca</a></li>
          <li><a href="/#cotizador">Cotiza tu apartamento</a></li>
        </ul>
      </div>
      <div>
        <h4>Empresa</h4>
        <ul>
          <li><a href="/proyectos">Proyectos entregados</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/#por-que">Por qué Espazios</a></li>
          <li><a href="/#contacto">Contacto</a></li>
        </ul>
      </div>
      <div class="footer-contacto">
        <h4>Contacto</h4>
        <p>📞 <a href="https://wa.me/573108708467" target="_blank" rel="noopener">+57 310 870 8467</a></p>
        <p>📧 <a href="mailto:espazios.co@gmail.com">espazios.co@gmail.com</a></p>
        <p>📍 Cl. 65 # 11 - 34<br/>Of. 305B, Chapinero<br/>Bogotá, Colombia</p>
        <p class="footer-socials">
          <a href="https://www.tiktok.com/@espazios" target="_blank" rel="noopener">TikTok</a> ·
          <a href="https://www.instagram.com/espazios.com.co/" target="_blank" rel="noopener">Instagram</a> ·
          <a href="https://facebook.com/espazios.co" target="_blank" rel="noopener">Facebook</a>
        </p>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {currentYear} Espazios. Todos los derechos reservados.</span>
      <span>
        <a href="/politica-privacidad">Política de privacidad</a> ·
        <a href="/terminos">Términos</a> ·
        <a href="/habeas-data">Habeas Data</a>
      </span>
    </div>
  </div>
</footer>

<style>
  footer {
    background: #0d2429; color: rgba(255,255,255,0.72);
    padding: var(--space-16) 0 var(--space-8);
    margin-top: var(--space-16);
  }
  .footer-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-8); }
  @media (min-width: 700px) { .footer-grid { grid-template-columns: 1.5fr 1fr 1fr 1.3fr; } }
  footer h4 {
    color: #fff; font-family: 'Inter', sans-serif; font-weight: 600;
    font-size: 0.95rem; margin-bottom: var(--space-4);
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  footer ul { list-style: none; padding: 0; }
  footer li { margin-bottom: var(--space-2); }
  footer a {
    color: rgba(255,255,255,0.72); text-decoration: none;
    font-size: 0.9rem; transition: color var(--t-fast);
  }
  footer a:hover { color: var(--c-verde-claro); }
  .footer-brand { display: flex; flex-direction: column; gap: var(--space-3); }
  .footer-logo { display: inline-block; }
  .footer-logo :global(.logo) {
    height: 44px;
    opacity: 0.95;
  }
  .footer-tagline {
    font-family: 'Fraunces', serif; font-style: italic;
    color: rgba(255,255,255,0.72);
    font-size: 0.95rem;
    max-width: 280px;
  }
  .footer-contacto p { font-size: 0.9rem; margin-bottom: var(--space-2); line-height: 1.5; }
  .footer-socials { margin-top: var(--space-3); }
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: var(--space-6); margin-top: var(--space-12);
    display: flex; flex-wrap: wrap; justify-content: space-between;
    gap: var(--space-4);
    font-size: var(--fs-small); color: rgba(255,255,255,0.5);
  }
</style>
