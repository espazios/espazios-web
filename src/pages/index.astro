---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Cotizador from '../components/Cotizador.astro';
import ProductosGrid from '../components/ProductosGrid.astro';
import Aliados from '../components/Aliados.astro';
import ProyectosPreview from '../components/ProyectosPreview.astro';
import ComoFunciona from '../components/ComoFunciona.astro';
import PorQue from '../components/PorQue.astro';
import Testimonios from '../components/Testimonios.astro';
import BlogPreview from '../components/BlogPreview.astro';
---

<Layout
  title="Espazios — Acabados de apartamentos en obra gris · Bogotá"
  description="Especialistas en remodelación de apartamentos en obra gris en Bogotá. Full acabados, solo carpintería o solo obra blanca. Desde 15 millones."
  activeNav="home"
>
  <Hero />
  <Cotizador />
  <ProductosGrid />
  <Aliados />
  <ProyectosPreview />
  <ComoFunciona />
  <PorQue />
  <Testimonios />
  <BlogPreview />

  <section class="cta-final" id="contacto">
    <div class="container">
      <div class="reveal">
        <h2>¿Listo para terminar tu apartamento?</h2>
        <p>Cotización transparente en menos de 24 horas hábiles. Sin compromiso.</p>
        <a href="#cotizador" class="btn btn-primary btn-large" style="background: var(--c-verde-claro); color: var(--c-azul-profundo);">Cotizar ahora →</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .cta-final { background: var(--c-azul-profundo); color: #fff; text-align: center; }
  .cta-final h2 { color: #fff; font-size: var(--fs-h1); margin-bottom: var(--space-4); }
  .cta-final p { color: rgba(255,255,255,0.7); font-size: 1.1rem; margin-bottom: var(--space-8); max-width: 540px; margin-left: auto; margin-right: auto; }
</style>
