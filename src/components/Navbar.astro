---
import Logo from './Logo.astro';

interface Props {
  activeNav?: 'home' | 'servicios' | 'proyectos' | 'cotizador' | 'blog' | 'contacto';
}
const { activeNav } = Astro.props;

const links = [
  { href: '/#productos', label: 'Servicios', key: 'servicios' },
  { href: '/proyectos', label: 'Proyectos', key: 'proyectos' },
  { href: '/#cotizador', label: 'Cotizar', key: 'cotizador' },
  { href: '/blog', label: 'Blog', key: 'blog' },
  { href: '/#contacto', label: 'Contacto', key: 'contacto' },
];
---

<nav class="navbar" aria-label="Navegación principal">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Espazios — Inicio">
      <Logo />
    </a>

    <ul class="nav-links">
      {links.map((link) => (
        <li>
          <a href={link.href} class={activeNav === link.key ? 'active' : ''}>{link.label}</a>
        </li>
      ))}
    </ul>

    <a href="/#cotizador" class="btn btn-primary nav-cta">Cotizar →</a>

    <button
      class="menu-toggle"
      id="menuToggle"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobileMenu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<style>
  .navbar {
    position: sticky; top: 0; z-index: 100;
    background: rgba(250, 251, 250, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--c-border);
  }
  .nav-inner {
    display: flex; align-items: center; justify-content: space-between;
    padding: var(--space-3) var(--space-6);
    max-width: 1280px; margin: 0 auto;
    gap: var(--space-4);
  }
  .nav-logo {
    flex-shrink: 0;
    display: flex; align-items: center;
    text-decoration: none;
    min-height: 44px;
  }
  .nav-links { display: none; gap: var(--space-8); list-style: none; }
  @media (min-width: 900px) { .nav-links { display: flex; } }
  .nav-links a {
    color: var(--c-text-body); text-decoration: none;
    font-size: 0.95rem; font-weight: 500;
    transition: color var(--t-fast);
  }
  .nav-links a:hover, .nav-links a.active { color: var(--c-verde-texto); }
  .nav-cta { padding: 10px 20px; min-height: 44px; display: none; }
  @media (min-width: 900px) { .nav-cta { display: inline-flex; } }
  .menu-toggle {
    display: flex; flex-direction: column; justify-content: center;
    width: 44px; height: 44px;
    background: transparent; border: none; cursor: pointer;
    padding: 0; gap: 5px;
    position: relative; z-index: 102;
  }
  .menu-toggle span {
    display: block; width: 22px; height: 2px;
    background: var(--c-text-strong); border-radius: 2px;
    transition: transform 300ms cubic-bezier(0.22, 1, 0.36, 1), opacity 200ms, background 200ms;
    margin: 0 auto;
  }
  .menu-toggle[aria-expanded="true"] span { background: #fff; }
  .menu-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .menu-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .menu-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  @media (min-width: 900px) { .menu-toggle { display: none; } }
</style>
