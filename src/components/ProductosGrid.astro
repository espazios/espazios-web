---
const productos = [
  {
    titulo: 'Full Acabados',
    sub: 'Te entregamos el apartamento listo para mudarte.',
    bullets: [
      'Pisos, enchape y pintura profesional',
      'Cocina integral + closets a la medida',
      'Baños completos terminados',
      'Diseño 3D antes de iniciar la obra',
    ],
    cobertura: 'Desde 15 millones · Bogotá',
    recomendado: true,
    placeholder: 'Foto: Cocina + sala terminadas (recomendado: Centrik Park, Nova Tramonte o Sabantti)',
    cta: 'Cotizar full acabados',
  },
  {
    titulo: 'Solo Carpintería',
    sub: 'Diseñamos y fabricamos cocina, closets y muebles a la medida.',
    bullets: [
      'Cocina integral con mesón en cuarzo o granito',
      'Closets de habitación y baño',
      'Muebles auxiliares (TV, escritorio)',
      'Termolaminados o lacados de alta gama',
    ],
    cobertura: 'Cotización personalizada · Bogotá',
    recomendado: false,
    placeholder: 'Foto: Cocina y closet a la medida (recomendado: Tramonte Living o Vértice)',
    cta: 'Cotizar carpintería',
  },
  {
    titulo: 'Solo Obra Blanca',
    sub: 'Pisos, enchapes y pintura. Tú decides los muebles después.',
    bullets: [
      'Porcelanato, laminado o vinílico',
      'Enchape de baños y cocina',
      'Pintura técnica anti-humedad',
      'Drywall y cielos rasos',
    ],
    cobertura: 'Cotización personalizada · Bogotá',
    recomendado: false,
    placeholder: 'Foto: Detalle de enchape o piso terminado',
    cta: 'Cotizar obra blanca',
  },
];
---

<section id="productos">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">ELIGE TU MODALIDAD</span>
      <h2>Tres formas de trabajar con nosotros</h2>
      <p>Tu apartamento, tu presupuesto, tu ritmo. Elige el paquete que se ajusta a lo que necesitas hoy.</p>
    </div>
    <div class="productos-grid">
      {productos.map((p) => (
        <article class="producto-card reveal">
          <div class="producto-img">
            {p.recomendado && <div class="producto-badge">Más solicitado</div>}
            <div class="placeholder-img">{p.placeholder}</div>
          </div>
          <div class="producto-body">
            <h3>{p.titulo}</h3>
            <p class="sub">{p.sub}</p>
            <ul class="producto-bullets">
              {p.bullets.map((b) => <li>{b}</li>)}
            </ul>
            <span class="cobertura">{p.cobertura}</span>
            <a href="/cotiza" class="btn btn-primary">{p.cta} →</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .productos-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-6); }
  @media (min-width: 900px) { .productos-grid { grid-template-columns: repeat(3, 1fr); } }
  .producto-card {
    background: var(--c-bg-elev); border-radius: var(--radius-lg);
    overflow: hidden; box-shadow: var(--shadow-soft);
    transition: transform var(--t-base), box-shadow var(--t-base);
    display: flex; flex-direction: column; position: relative;
  }
  .producto-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-medium); }
  .producto-img { height: 220px; position: relative; overflow: hidden; }
  .placeholder-img {
    width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, var(--c-verde-neutro), var(--c-verde-salvia));
    color: rgba(255,255,255,0.85); font-family: 'Fraunces', serif; font-style: italic;
    font-size: 0.85rem; padding: var(--space-4); text-align: center;
  }
  .producto-badge {
    position: absolute; top: var(--space-4); left: var(--space-4);
    background: var(--c-azul-profundo); color: var(--c-verde-claro);
    padding: 6px 12px; border-radius: var(--radius-pill);
    font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
    z-index: 2;
  }
  .producto-body { padding: var(--space-6); flex: 1; display: flex; flex-direction: column; }
  .producto-card h3 { font-size: var(--fs-h3); margin-bottom: var(--space-2); }
  .producto-card .sub { color: var(--c-text-muted); font-size: 0.95rem; margin-bottom: var(--space-4); }
  .producto-bullets { list-style: none; margin-bottom: var(--space-4); flex: 1; padding: 0; }
  .producto-bullets li { display: flex; align-items: start; gap: var(--space-2); font-size: 0.92rem; m