---
const links = [
  { href: '/#productos', label: 'Servicios' },
  { href: '/proyectos', label: 'Proyectos' },
  { href: '/#cotizador', label: 'Cotizar' },
  { href: '/blog', label: 'Blog' },
  { href: '/#contacto', label: 'Contacto' },
];
---

<div class="mobile-menu" id="mobileMenu" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Menú principal">
  <button class="mobile-close" id="mobileClose" aria-label="Cerrar menú">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M6 6L18 18M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
    <span>Cerrar</span>
  </button>

  <nav class="mobile-nav">
    <ul>
      {links.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
    <div class="mobile-menu-cta">
      <a href="/#cotizador" class="btn btn-primary">Cotiza tu apartamento →</a>
    </div>
  </nav>
</div>

<style>
  .mobile-menu {
    position: fixed; inset: 0;
    background: rgba(22, 56, 64, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: 101;
    opacity: 0; visibility: hidden;
    transition: opacity 300ms, visibility 0s 300ms;
    display: flex; flex-direction: column;
  }
  .mobile-menu[aria-hidden="false"] {
    opacity: 1; visibility: visible;
    transition: opacity 300ms;
  }
  .mobile-close {
    position: absolute;
    top: var(--space-4); right: var(--space-4);
    display: inline-flex; align-items: center; gap: var(--space-2);
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: var(--radius-pill);
    padding: 10px 18px;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem; font-weight: 600;
    cursor: pointer;
    z-index: 103;
    min-height: 44px;
    transition: background var(--t-fast), border-color var(--t-fast);
  }
  .mobile-close:hover, .mobile-close:focus-visible {
    background: rgba(128, 191, 155, 0.25);
    border-color: var(--c-verde-claro);
    outline: none;
  }
  .mobile-close svg { display: block; }
  .mobile-nav {
    flex: 1;
    display: flex; flex-direction: column; justify-content: center; align-items: center;
    padding: var(--space-16) var(--space-6) var(--space-12);
  }
  .mobile-nav ul {
    list-style: none; text-align: center;
    display: flex; flex-direction: column; gap: var(--space-4);
    padding: 0; margin: 0;
  }
  .mobile-nav a {
    color: #fff; text-decoration: none;
    font-family: 'Fraunces', serif; font-size: 1.875rem; font-weight: 500;
    display: inline-block; padding: var(--space-3) var(--space-6);
    transition: color 200ms;
    min-height: 44px;
  }
  .mobile-nav a:hover, .mobile-nav a:focus { color: var(--c-verde-claro); outline: none; }
  .mobile-menu-cta { margin-top: var(--space-8); display: flex; justify-content: center; }
  .mobile-menu-cta :global(.btn-primary) {
    background: var(--c-verde-claro); color: var(--c-azul-profundo);
    padding: 16px 36px;
  }
  :global(body.menu-open) { overflow: hidden; }
  @media (min-width: 900px) { .mobile-menu { display: none; } }
</style>

<script>
  const toggle = document.getElementById('menuToggle');
  const menu = document.getElementById('mobileMenu');
  const closeBtn = document.getElementById('mobileClose');
  if (toggle && menu) {
    const setOpen = (open) => {
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
      menu.setAttribute('aria-hidden', String(!open));
      document.body.classList.toggle('menu-open', open);
    };
    toggle.addEventListener('click', () => {
      setOpen(toggle.getAttribute('aria-expanded') !== 'true');
    });
    if (closeBtn) closeBtn.addEventListener('click', () => setOpen(false));
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') setOpen(false);
    });
  }
</script>
