---
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <div>
        <a href="/" class="footer-logo-placeholder">esp<span>azios</span></a>
        <p class="footer-tagline">Acabados y remodelación con respaldo.</p>
      </div>
      <div>
        <h4>Servicios</h4>
        <ul>
          <li><a href="/#productos">Remodelación completa</a></li>
          <li><a href="/#productos">Carpintería</a></li>
          <li><a href="/#productos">Solo acabados</a></li>
          <li><a href="/cotiza">Cotizar mi proyecto</a></li>
        </ul>
      </div>
      <div>
        <h4>Empresa</h4>
        <ul>
          <li><a href="/proyectos">Proyectos</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/#contacto">Contacto</a></li>
          <li><a href="/#por-que">Por qué Espazios</a></li>
        </ul>
      </div>
      <div class="footer-contacto">
        <h4>Contacto</h4>
        <p>📞 +57 305 288 5923</p>
        <p>📧 espazios.co@gmail.com</p>
        <p>📍 Bogotá, Colombia</p>
        <p style="margin-top: var(--space-3);">
          <a href="https://instagram.com/espazios.co" target="_blank" rel="noopener">Instagram</a> ·
          <a href="https://facebook.com/espazios.co" target="_blank" rel="noopener">Facebook</a> ·
          <a href="https://tiktok.com/@espazios.co" target="_blank" rel="noopener">TikTok</a>
        </p>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {currentYear} Espazios. Todos los derechos reservados.</span>
      <span>
        <a href="/politica-privacidad">Política de privacidad</a> ·
        <a href="/terminos">Términos</a> ·
        <a href="/habeas-data">Habeas Data</a>
      </span>
    </div>
  </div>
</footer>

<style>
  footer {
    background: #0d2429; color: rgba(255,255,255,0.7);
    padding: var(--space-16) 0 var(--space-8);
    margin-top: var(--space-16);
  }
  .footer-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-8); }
  @media (min-width: 700px) { .footer-grid { grid-template-columns: 1.5fr 1fr 1fr 1.2fr; } }
  footer h4 {
    color: #fff; font-family: 'Inter', sans-serif; font-weight: 600;
    font-size: 0.95rem; margin-bottom: var(--space-4);
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  footer ul { list-style: none; padding: 0; }
  footer li { margin-bottom: var(--space-2); }
  footer a {
    color: rgba(255,255,255,0.7); text-decoration: none;
    font-size: 0.9rem; transition: color var(--t-fast);
  }
  footer a:hover { color: var(--c-verde-claro); }
  .footer-logo-placeholder {
    width: 180px; height: 50px; display: flex;
    background: linear-gradient(135deg, var(--c-verde-salvia), var(--c-verde-claro));
    border-radius: var(--radius-sm);
    align-items: center; justify-content: center;
    color: var(--c-azul-profundo); font-family: 'Fraunces', serif;
    font-size: 1.2rem; font-weight: 600;
    text-decoration: none;
  }
  .footer-logo-placeholder span { color: var(--c-azul-profundo); font-weight: 700; }
  .footer-tagline {
    font-family: 'Fraunces', serif; font-style: italic;
    color: rgba(255,255,255,0.7);
    margin-top: var(--space-3); font-size: 0.95rem;
  }
  .footer-contacto p { font-size: 0.9rem; margin-bottom: var(--space-2); }
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: var(--space-6); margin-top: var(--space-12);
    display: flex; flex-wrap: wrap; justify-content: space-between;
    gap: var(--space-4);
    font-size: var(--fs-small); color: rgba(255,255,255,0.5);
  }
</style>
