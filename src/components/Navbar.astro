---
interface Props {
  activeNav?: 'home' | 'servicios' | 'proyectos' | 'cotizador' | 'blog' | 'contacto';
}
const { activeNav } = Astro.props;

const links = [
  { href: '/#productos', label: 'Servicios', key: 'servicios' },
  { href: '/proyectos', label: 'Proyectos', key: 'proyectos' },
  { href: '/cotiza', label: 'Cotizar', key: 'cotizador' },
  { href: '/blog', label: 'Blog', key: 'blog' },
  { href: '/#contacto', label: 'Contacto', key: 'contacto' },
];
---

<nav class="navbar">
  <div class="nav-inner">
    <a href="/" class="logo-placeholder" aria-label="Espazios - Inicio">esp<span>azios</span></a>

    <ul class="nav-links">
      {links.map((link) => (
        <li>
          <a href={link.href} class={activeNav === link.key ? 'active' : ''}>{link.label}</a>
        </li>
      ))}
    </ul>

    <a href="/cotiza" class="btn btn-primary nav-cta">Cotizar →</a>

    <button
      class="menu-toggle"
      id="menuToggle"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobileMenu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<style>
  .navbar {
    position: sticky; top: 0; z-index: 100;
    background: rgba(250, 251, 250, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--c-border);
  }
  .nav-inner {
    display: flex; align-items: center; justify-content: space-between;
    padding: var(--space-4) var(--space-6);
    max-width: 1280px; margin: 0 auto;
    gap: var(--space-4);
  }
  .logo-placeholder {
    width: 160px; height: 44px; flex-shrink: 0;
    background: linear-gradient(135deg, var(--c-azul-profundo), var(--c-azul-pizarra));
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-family: 'Fraunces', serif;
    font-size: 1.1rem; font-weight: 500;
    letter-spacing: -0.02em;
    text-decoration: none;
  }
  .logo-placeholder span { color: var(--c-verde-claro); }

  .nav-links {
    display: none; gap: var(--space-8); list-style: none;
  }
  @media (min-width: 900px) { .nav-links { display: flex; } }
  .nav-links a {
    color: var(--c-text-body); text-decoration: none;
    font-size: 0.95rem; font-weight: 500;
    transition: color var(--t-fast);
  }
  .nav-links a:hover, .nav-links a.active { color: var(--c-verde-texto); }

  /* CTA navbar oculto en mobile */
  .nav-cta { padding: 10px 20px; min-height: 44px; display: none; }
  @media (min-width: 900px) { .nav-cta { display: inline-flex; } }

  /* Botón hamburguesa */
  .menu-toggle {
    display: flex; flex-direction: column; justify-content: center;
    width: 44px; height: 44px;
    background: transparent; border: none; cursor: pointer;
    padding: 0; gap: 5px;
    position: relative; z-index: 102;
  }
  .menu-toggle span {
    display: block; width: 22px; height: 2px;
    background: var(--c-text-strong); border-radius: 2px;
    transition: transform 300ms cubic-bezier(0.22, 1, 0.36, 1), opacity 200ms;
    margin: 0 auto;
  }
  .menu-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .menu-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .menu-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  @media (min-width: 900px) { .menu-toggle { display: none; } }
</style>
