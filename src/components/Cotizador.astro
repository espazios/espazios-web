---
const calendarUrl = import.meta.env.GOOGLE_CALENDAR_URL || 'https://calendar.google.com/calendar/appointments/schedules/AcZssZ2JoOnboCFBDmNXuAjfh7hXLnAO2dqw9dMteg9N1iZLpHxoVL0ODnFWU2zIrfQN9vOKKxPyaQMT';
---
 
<section id="cotizador" class="cotizador">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow" style="color: var(--c-verde-claro);">Cotizador conversacional</span>
      <h2>Tu cotización en 3 minutos</h2>
      <p>Te hacemos 6 preguntas rápidas y nuestro equipo te contacta con propuesta personalizada.</p>
    </div>
 
    <div class="cotizador-card reveal">
      <div class="save-indicator" id="saveIndicator">Guardado ✓</div>
 
      <div class="progress-row">
        <div class="progress-track"><div class="progress-fill" id="progressFill"></div></div>
        <span class="progress-label"><span id="stepNum">1</span> de 6</span>
      </div>
 
      <div class="step active" data-step="1">
        <div class="isa-bubble">
          <div class="isa-avatar">I</div>
          <div class="text">Hola 👋 Soy <strong>Isa de Espazios</strong>. Voy a acompañarte mientras cotizas tu proyecto.</div>
        </div>
        <h3>Transformemos tu vivienda en el espacio que tienes en mente.</h3>
        <p class="pregunta">¿Con quién tengo el gusto?</p>
        <div class="field"><label>Nombre completo</label><input type="text" id="inpNombre" placeholder="Ej: María Camila Pérez" autocomplete="name" /></div>
        <div class="field"><label>Correo electrónico</label><input type="email" id="inpEmail" placeholder="tu@email.com" autocomplete="email" inputmode="email" /></div>
        <div class="field"><label>Número celular</label><input type="tel" id="inpCelular" placeholder="3xx xxx xxxx" autocomplete="tel" inputmode="tel" /></div>
 
        <!-- Honeypot: invisible para humanos, visible para bots que llenan todo -->
        <div class="hp-field" aria-hidden="true">
          <label for="inpWebsite">No llenar este campo</label>
          <input type="text" id="inpWebsite" name="website" tabindex="-1" autocomplete="off" />
        </div>
 
        <!-- Habeas Data — Ley 1581/2012 Colombia -->
        <label class="hd-check">
          <input type="checkbox" id="inpConsentimiento" />
          <span>
            Acepto la <a href="/politica-privacidad" target="_blank" rel="noopener">Política de Tratamiento de Datos</a>
            y autorizo a Espazios a usar mi información para contactarme sobre esta cotización.
            <em>(Ley 1581 de 2012 · Colombia)</em>
          </span>
        </label>
 
        <div class="btn-row"><button class="btn btn-primary" id="btnPaso1" disabled>Continuar →</button></div>
      </div>
 
      <div class="step" data-step="2">
        <h3>Cuéntanos sobre tu proyecto</h3>
        <p class="pregunta">¿Qué tipo de remodelación quieres realizar?</p>
        <div class="opciones">
          <button class="opcion" data-tipo="Full Acabados">
            <span class="opcion-recomendado">Recomendado</span>
            <div class="opcion-titulo">Full Acabados</div>
            <div class="opcion-desc">Paquete completo: pisos, enchape, cocina y carpintería.</div>
          </button>
          <button class="opcion" data-tipo="Solo Carpintería">
            <div class="opcion-titulo">Solo Carpintería</div>
            <div class="opcion-desc">Cocina, closets, puertas, muebles baño y mobiliario.</div>
          </button>
          <button class="opcion" data-tipo="Solo Obra Blanca">
            <div class="opcion-titulo">Solo Obra Blanca</div>
            <div class="opcion-desc">Enchapes, pintura, divisiones y terminaciones.</div>
          </button>
        </div>
        <div class="btn-row"><button class="btn btn-ghost" data-back>← Volver</button></div>
      </div>
 
      <div class="step" data-step="3">
        <h3>¿Dónde está ubicado tu inmueble?</h3>
        <p class="pregunta">Esto nos ayuda a confirmar cobertura.</p>
        <div class="opciones">
          <button class="opcion" data-ciudad="Bogotá"><div class="opcion-titulo">Bogotá</div><div class="opcion-desc">Selecciona si queda dentro de Bogotá.</div></button>
          <button class="opcion" data-ciudad="Soacha"><div class="opcion-titulo">Soacha</div><div class="opcion-desc">Selecciona si queda dentro de Soacha.</div></button>
          <button class="opcion" data-ciudad="Alrededores Bogotá"><div class="opcion-titulo">Alrededores de Bogotá</div><div class="opcion-desc">Mosquera, Madrid, Chía, Cota, Zipaquirá, Cajicá, La Calera.</div></button>
        </div>
        <div class="field" style="margin-top: var(--space-6);"><label>Torre / conjunto / barrio (opcional)</label><input type="text" id="inpBarrio" placeholder="Ej: Centrik Park, Nova Tramonte, Cedritos" /></div>
        <div class="btn-row"><button class="btn btn-ghost" data-back>← Volver</button><button class="btn btn-primary" id="btnPaso3" disabled>Continuar →</button></div>
      </div>
 
      <div class="step" data-step="4">
        <h3>¿Cuál es tu presupuesto aproximado?</h3>
        <p class="pregunta">Esto es solo una referencia para entender la escala del proyecto.</p>
        <div class="opciones">
          <button class="opcion" data-presupuesto="Menos de $15 millones"><div class="opcion-titulo">Menos de $15 millones</div></button>
          <button class="opcion" data-presupuesto="Entre $15 y $25 millones"><div class="opcion-titulo">Entre $15 y $25 millones</div></button>
          <button class="opcion" data-presupuesto="Entre $25 y $40 millones"><div class="opcion-titulo">Entre $25 y $40 millones</div></button>
          <button class="opcion" data-presupuesto="Más de $40 millones"><div class="opcion-titulo">Más de $40 millones</div></button>
        </div>
        <div class="btn-row"><button class="btn btn-ghost" data-back>← Volver</button></div>
      </div>
 
      <div class="step" data-step="5">
        <h3>¿Cuándo te gustaría comenzar?</h3>
        <p class="pregunta">Para coordinar agenda y disponibilidad de equipo.</p>
        <div class="opciones">
          <button class="opcion" data-tiempo="Inmediato"><div class="opcion-titulo">⚡ Inmediato</div></button>
          <button class="opcion" data-tiempo="De 1 a 2 meses"><div class="opcion-titulo">📅 De 1 a 2 meses</div></button>
          <button class="opcion" data-tiempo="De 3 a 4 meses"><div class="opcion-titulo">📅 De 3 a 4 meses</div></button>
          <button class="opcion" data-tiempo="De 5 a 6 meses"><div class="opcion-titulo">📅 De 5 a 6 meses</div></button>
          <button class="opcion" data-tiempo="Más de 6 meses"><div class="opcion-titulo">📅 Más de 6 meses</div></button>
        </div>
        <div class="btn-row"><button class="btn btn-ghost" data-back>← Volver</button></div>
      </div>
 
      <div class="step" data-step="6">
        <div class="isa-bubble"><div class="isa-avatar">I</div><div class="text">Estamos cerca. <strong>Falta poco para tu cotización.</strong></div></div>
        <h3>Agenda una asesoría personalizada</h3>
        <p class="pregunta">Uno de nuestros expertos te ayudará a aterrizar tu proyecto y preparar una propuesta.</p>
        <div class="opciones cols-3">
          <button class="opcion" data-canal="Llamada"><div class="opcion-titulo">📞 Llamada</div><div class="opcion-desc">10–15 min, telefónica.</div></button>
          <button class="opcion" data-canal="Videollamada"><div class="opcion-titulo">🎥 Videollamada</div><div class="opcion-desc">Google Meet con pantalla.</div></button>
          <button class="opcion" data-canal="Visita"><div class="opcion-titulo">🏠 Visita</div><div class="opcion-desc">En tu vivienda, sin costo.</div></button>
        </div>
        <div class="btn-row" style="flex-direction: column; gap: var(--space-3);">
          <button class="btn btn-primary btn-large" id="btnAgendar" data-calendar-url={calendarUrl} style="width: 100%;">Agendar reunión →</button>
          <button class="btn btn-ghost" id="btnLlamenme">Prefiero que me llamen</button>
        </div>
      </div>
 
      <div class="step" data-step="success">
        <div class="success-card">
          <div class="check">✓</div>
          <h3>¡Listo, recibimos tu solicitud!</h3>
          <p class="pregunta" style="max-width: 420px; margin: var(--space-3) auto var(--space-6);">
            Uno de nuestros expertos te contactará en menos de 24 horas hábiles. Mientras tanto, puedes ver algunos de nuestros proyectos.
          </p>
          <a href="/proyectos" class="btn btn-primary">Ver proyectos →</a>
        </div>
      </div>
    </div>
  </div>
</section>
 
<style>
  .cotizador {
    background: linear-gradient(180deg, var(--c-azul-profundo) 0%, #0d2429 100%);
    color: #fff; position: relative; overflow: hidden;
  }
  .cotizador::before {
    content: ""; position: absolute; top: -100px; right: -100px;
    width: 400px; height: 400px; border-radius: 50%;
    background: radial-gradient(circle, rgba(118, 166, 143, 0.2) 0%, transparent 70%);
  }
  .cotizador :global(h2), .cotizador :global(h3) { color: #fff; }
  .cotizador .section-head p { color: rgba(255,255,255,0.7); }
 
  .cotizador-card {
    max-width: 680px; margin: 0 auto;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    backdrop-filter: blur(12px);
    position: relative; z-index: 1;
  }
  @media (min-width: 768px) { .cotizador-card { padding: var(--space-12); } }
 
  .progress-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-8); }
  .progress-track { flex: 1; height: 4px; background: rgba(255,255,255,0.12); border-radius: var(--radius-pill); overflow: hidden; }
  .progress-fill { height: 100%; background: linear-gradient(90deg, var(--c-verde-salvia), var(--c-verde-claro)); border-radius: var(--radius-pill); transition: width 500ms ease; width: 16.66%; }
  .progress-label { font-size: var(--fs-small); color: rgba(255,255,255,0.7); font-variant-numeric: tabular-nums; margin-left: var(--space-4); }
 
  .isa-bubble { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-6); }
  .isa-avatar { width: 48px; height: 48px; flex-shrink: 0; background: var(--c-verde-neutro); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Fraunces', serif; color: var(--c-azul-profundo); font-weight: 600; font-size: 1.1rem; }
  .isa-bubble .text { font-size: 0.95rem; color: rgba(255,255,255,0.85); }
  .isa-bubble .text strong { color: #fff; font-weight: 500; }
 
  .step { display: none; animation: fadeUp 400ms cubic-bezier(0.22, 1, 0.36, 1); }
  .step.active { display: block; }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  .step h3 { font-size: 1.6rem; margin-bottom: var(--space-3); font-family: 'Fraunces', serif; }
  .step .pregunta { color: rgba(255,255,255,0.7); margin-bottom: var(--space-6); font-size: 1rem; }
 
  .field { margin-bottom: var(--space-4); }
  .field label { display: block; font-size: 0.85rem; color: rgba(255,255,255,0.7); margin-bottom: var(--space-2); font-weight: 500; }
  .field input { width: 100%; padding: 14px var(--space-4); background: rgba(255,255,255,0.08); color: #fff; border: 1.5px solid rgba(255,255,255,0.12); border-radius: var(--radius-md); font-size: 1rem; transition: border-color var(--t-fast), background var(--t-fast); font-family: inherit; }
  .field input:focus { outline: none; border-color: var(--c-verde-claro); background: rgba(255,255,255,0.12); }
  .field input::placeholder { color: rgba(255,255,255,0.4); }
 
  /* Honeypot: invisible pero presente en DOM para bots */
  .hp-field {
    position: absolute !important;
    left: -9999px !important;
    top: -9999px !important;
    width: 1px; height: 1px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
  }
 
  /* Habeas Data — checkbox de consentimiento */
  .hd-check {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius-md);
    margin: var(--space-4) 0 var(--space-6);
    cursor: pointer;
    transition: background var(--t-fast), border-color var(--t-fast);
  }
  .hd-check:hover { background: rgba(255,255,255,0.08); border-color: rgba(128,191,155,0.4); }
  .hd-check input[type="checkbox"] {
    width: 20px; height: 20px;
    flex-shrink: 0;
    margin-top: 2px;
    cursor: pointer;
    accent-color: var(--c-verde-claro);
  }
  .hd-check span {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.85);
    line-height: 1.5;
  }
  .hd-check a {
    color: var(--c-verde-claro);
    text-decoration: underline;
  }
  .hd-check em {
    font-style: italic;
    color: rgba(255,255,255,0.5);
    font-size: 0.78rem;
    display: block;
    margin-top: 4px;
  }
 
  .opciones { display: grid; grid-template-columns: 1fr; gap: var(--space-3); }
  @media (min-width: 600px) { .opciones.cols-3 { grid-template-columns: repeat(3, 1fr); } }
 
  .opcion { background: rgba(255,255,255,0.06); color: #fff; border: 1.5px solid rgba(255,255,255,0.12); border-radius: var(--radius-md); padding: var(--space-4) var(--space-5); cursor: pointer; text-align: left; transition: all var(--t-fast); position: relative; font-family: inherit; }
  .opcion:hover { background: rgba(255,255,255,0.1); border-color: var(--c-verde-claro); transform: translateX(2px); }
  .opcion.selected { background: rgba(118, 166, 143, 0.2); border-color: var(--c-verde-claro); }
  .opcion-titulo { font-weight: 600; font-size: 1rem; margin-bottom: var(--space-1); }
  .opcion-desc { font-size: 0.85rem; color: rgba(255,255,255,0.6); }
  .opcion-recomendado { position: absolute; top: -10px; right: 12px; background: var(--c-verde-claro); color: var(--c-azul-profundo); padding: 3px 10px; border-radius: var(--radius-pill); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.06em; }
 
  .btn-row { display: flex; gap: var(--space-3); justify-content: space-between; margin-top: var(--space-8); align-items: center; }
  .btn-row :global(.btn-ghost) { color: rgba(255,255,255,0.6); }
  .btn-row :global(.btn-ghost):hover { color: #fff; }
  .btn-row :global(.btn-primary) { margin-left: auto; }
 
  .save-indicator { position: absolute; top: var(--space-4); right: var(--space-4); font-size: var(--fs-small); color: var(--c-verde-claro); opacity: 0; transition: opacity 200ms; font-weight: 500; }
  .save-indicator.visible { opacity: 1; }
 
  .success-card { text-align: center; }
  .success-card .check { width: 64px; height: 64px; border-radius: 50%; background: var(--c-verde-claro); color: var(--c-azul-profundo); display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: 700; margin: 0 auto var(--space-6); }
</style>
 
<script>
  // Cotizador con sync a /api/lead (HubSpot) + honeypot + Habeas Data
  const state: Record<string, unknown> = JSON.parse(localStorage.getItem('espazios_lead') || '{}');
  let currentStep = 1;
  let canalElegido: string | null = null;
  let ciudadElegida: string | null = null;
  const STORAGE_LEAD_ID = 'espazios_lead_id';
 
  function uuid() {
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {
      const r = Math.random() * 16 | 0;
      return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
    });
  }
  function getLeadId() {
    let id = localStorage.getItem(STORAGE_LEAD_ID);
    if (!id) { id = uuid(); localStorage.setItem(STORAGE_LEAD_ID, id); }
    return id;
  }
  const leadId = getLeadId();
  const indicator = document.getElementById('saveIndicator')!;
  const progress = document.getElementById('progressFill')!;
  const stepNum = document.getElementById('stepNum')!;
 
  function showSave() {
    indicator.classList.add('visible');
    setTimeout(() => indicator.classList.remove('visible'), 1200);
  }
  async function syncToHubSpot(etapa: number) {
    showSave();
    try {
      await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ leadId, etapa, fields: state }),
      });
    } catch (e) {
      console.warn('[Cotizador] sync error, reintentando...', e);
      setTimeout(() => syncToHubSpot(etapa).catch(() => {}), 3000);
    }
  }
  function persistField(k: string, v: unknown) {
    state[k] = v;
    localStorage.setItem('espazios_lead', JSON.stringify(state));
  }
  function goToStep(n: number | 'success') {
    document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
    const sel = n === 'success' ? '[data-step="success"]' : `[data-step="${n}"]`;
    const el = document.querySelector(sel);
    if (el) el.classList.add('active');
    if (typeof n === 'number') {
      progress.style.width = (n / 6 * 100) + '%';
      stepNum.textContent = String(n);
      currentStep = n;
    } else {
      progress.style.width = '100%';
      stepNum.textContent = '6';
    }
    document.querySelector('.cotizador-card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
  function validEmail(e: string) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e); }
  function validateStep1() {
    const n = (document.getElementById('inpNombre') as HTMLInputElement).value.trim();
    const e = (document.getElementById('inpEmail') as HTMLInputElement).value.trim();
    const c = (document.getElementById('inpCelular') as HTMLInputElement).value.trim().replace(/\D/g, '');
    const consent = (document.getElementById('inpConsentimiento') as HTMLInputElement).checked;
    const ok = n.length >= 3 && validEmail(e) && c.length >= 10 && consent;
    (document.getElementById('btnPaso1') as HTMLButtonElement).disabled = !ok;
  }
  ['inpNombre', 'inpEmail', 'inpCelular'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', validateStep1);
  });
  document.getElementById('inpConsentimiento')?.addEventListener('change', validateStep1);
 
  document.getElementById('btnPaso1')?.addEventListener('click', async () => {
    // HONEYPOT: si el campo "website" está lleno = bot, simular éxito silencioso
    const honeypot = (document.getElementById('inpWebsite') as HTMLInputElement).value;
    if (honeypot) {
      console.warn('[Cotizador] honeypot triggered — silent success');
      goToStep(2);
      return;
    }
 
    persistField('nombre', (document.getElementById('inpNombre') as HTMLInputElement).value.trim());
    persistField('email', (document.getElementById('inpEmail') as HTMLInputElement).value.trim());
    persistField('celular', (document.getElementById('inpCelular') as HTMLInputElement).value.trim());
    persistField('consentimientoHabeasData', true);
    persistField('fechaConsentimiento', new Date().toISOString());
    await syncToHubSpot(1);
    goToStep(2);
  });
  document.querySelectorAll<HTMLElement>('[data-tipo]').forEach(btn => {
    btn.addEventListener('click', async () => {
      persistField('tipoProyecto', btn.dataset.tipo);
      await syncToHubSpot(2);
      setTimeout(() => goToStep(3), 200);
    });
  });
  document.querySelectorAll<HTMLElement>('[data-ciudad]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-ciudad]').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      ciudadElegida = btn.dataset.ciudad || null;
      (document.getElementById('btnPaso3') as HTMLButtonElement).disabled = false;
    });
  });
  document.getElementById('btnPaso3')?.addEventListener('click', async () => {
    persistField('ciudad', ciudadElegida);
    persistField('barrioConjunto', (document.getElementById('inpBarrio') as HTMLInputElement).value.trim());
    await syncToHubSpot(3);
    goToStep(4);
  });
  document.querySelectorAll<HTMLElement>('[data-presupuesto]').forEach(btn => {
    btn.addEventListener('click', async () => {
      persistField('presupuesto', btn.dataset.presupuesto);
      await syncToHubSpot(4);
      setTimeout(() => goToStep(5), 200);
    });
  });
  document.querySelectorAll<HTMLElement>('[data-tiempo]').forEach(btn => {
    btn.addEventListener('click', async () => {
      persistField('tiempoInicio', btn.dataset.tiempo);
      await syncToHubSpot(5);
      setTimeout(() => goToStep(6), 200);
    });
  });
  document.querySelectorAll<HTMLElement>('[data-canal]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-canal]').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      canalElegido = btn.dataset.canal || null;
    });
  });
  const btnAgendar = document.getElementById('btnAgendar');
  btnAgendar?.addEventListener('click', async () => {
    persistField('canalAsesoria', canalElegido || 'Llamada');
    persistField('completado', true);
    await syncToHubSpot(6);
    const url = btnAgendar.getAttribute('data-calendar-url')!;
    window.open(url, '_blank');
    goToStep('success');
  });
  document.getElementById('btnLlamenme')?.addEventListener('click', async () => {
    persistField('canalAsesoria', canalElegido || 'Llamada');
    persistField('completado', true);
    await syncToHubSpot(6);
    goToStep('success');
  });
  document.querySelectorAll<HTMLElement>('[data-back]').forEach(btn => {
    btn.addEventListener('click', () => { if (currentStep > 1) goToStep(currentStep - 1); });
  });
</script>
 
